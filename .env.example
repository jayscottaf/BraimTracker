# Neon Postgres — set by the Vercel Neon integration automatically on deploy.
# For local dev, copy these from your Neon dashboard (or run `vercel env pull`).
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"          # pooled
DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@HOST/DB?sslmode=require" # direct (for migrations)

# Vercel Blob (auto-injected when you add the Blob integration on Vercel)
BLOB_READ_WRITE_TOKEN=""

# Auth
JWT_SECRET="generate-a-long-random-string-32+chars"
OWNER_PASSWORD="choose-an-owner-password"
