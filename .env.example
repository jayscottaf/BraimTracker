# Neon Postgres (create free DB at https://neon.tech)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Vercel Blob (auto-injected when you add the Blob integration on Vercel)
BLOB_READ_WRITE_TOKEN=""

# Auth
JWT_SECRET="generate-a-long-random-string-32+chars"
OWNER_PASSWORD="choose-an-owner-password"
